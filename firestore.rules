rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    match /blogs/{blogId} {
      // Helper function to check if the user is an allowed admin
      function isAdmin() {
        return request.auth != null && 
               request.auth.token.email.toLowerCase() in [
                 'arvindyadav70075@gmail.com',
                 'admin@email.com', 
                 'client@email.com', 
                 'admin@sabkasaathi.in'
               ];
      }

      // Public can read only published blogs; Admins can read all blogs
      allow read: if isAdmin() || (resource == null || resource.data.status == 'published');
      
      // Admins can write all blogs
      allow write: if isAdmin();
    }
  }
}

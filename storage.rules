rules_version = '2';
service firebase.storage {
  match /b/{bucket}/o {
    match /blogs/{allPaths=**} {
      // Anyone can read blog images
      allow read: if true;
      
      // Only authenticated users with emails in the allowed list can upload or delete images
      allow write: if request.auth != null && 
        request.auth.token.email.toLowerCase() in [
          'admin@email.com', 
          'client@email.com', 
          'admin@sabkasaathi.in',
          'arvindyadav70075@gmail.com'
        ];
    }
  }
}
